# Lenovo XClarity Administrator → NetBox collector
# Copy this file to .env and fill in your values.
# All variables can also be set directly in your shell environment.

# ---------------------------------------------------------------------------
# XClarity Administrator
# ---------------------------------------------------------------------------

# Hostname or IP address of the XClarity Administrator instance (required)
XCLARITY_HOST=xclarity.example.com

# Port for the XClarity REST API (default: 443)
XCLARITY_PORT=443

# XClarity Administrator credentials (required)
XCLARITY_USERNAME=USERID
XCLARITY_PASSWORD=changeme

# Set to "false" only in lab/test environments where the certificate is self-signed
XCLARITY_VERIFY_SSL=true

# Timeout in seconds for XClarity API requests (default: 30)
XCLARITY_TIMEOUT=30

# ---------------------------------------------------------------------------
# NetBox
# ---------------------------------------------------------------------------

# URL of the NetBox instance — no trailing slash (required)
NETBOX_URL=https://netbox.example.com

# NetBox API token with read/write access (required)
NETBOX_TOKEN=0123456789abcdef0123456789abcdef01234567

# Site slug to assign to devices that carry no location information (default: default)
NETBOX_DEFAULT_SITE=default

# Device role slugs for each XClarity device category (defaults shown)
NETBOX_SERVER_ROLE=server
NETBOX_CHASSIS_ROLE=chassis
NETBOX_SWITCH_ROLE=switch
NETBOX_STORAGE_ROLE=storage

# Maximum NetBox API calls per second — 0 means unlimited (default: 5)
NETBOX_RATE_LIMIT=5

# Number of retry attempts for failed NetBox API calls (default: 3)
NETBOX_RETRY_ATTEMPTS=3

# ---------------------------------------------------------------------------
# Collector behaviour
# ---------------------------------------------------------------------------

# Comma-separated list of device categories to collect (default: all four)
# Supported values: nodes, chassis, switches, storage
COLLECTOR_CATEGORIES=nodes,chassis,switches,storage

# Sync network interfaces and IP addresses (default: true)
COLLECTOR_SYNC_INTERFACES=true

# Sync inventory items — CPUs, memory, PSUs, fans (default: true)
COLLECTOR_SYNC_INVENTORY=true

# When syncing inventory, use NetBox Modules instead of Inventory Items (default: false).
# Modules preserve slot/bay context (CPU sockets, DIMM slots, PCIe slots, PSU bays, fan bays)
# and are the recommended approach in NetBox 4.x.
# Setting this to true requires NetBox 4.0+ with the dcim.module_bay_templates API.
COLLECTOR_USE_MODULES=false

# Logging level: DEBUG, INFO, WARNING, ERROR (default: INFO)
COLLECTOR_LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Optional regex transformations (Python re.sub syntax)
# Leave the pattern empty to disable transformation.
# ---------------------------------------------------------------------------

# Transform device hostnames before writing to NetBox.
# Example — strip a domain suffix: COLLECTOR_HOSTNAME_REGEX=\.example\.com$
#                                   COLLECTOR_HOSTNAME_REPLACE=
COLLECTOR_HOSTNAME_REGEX=
COLLECTOR_HOSTNAME_REPLACE=

# Transform the XClarity location.location field (maps to NetBox site name).
COLLECTOR_LOCATION_REGEX=
COLLECTOR_LOCATION_REPLACE=

# Transform the XClarity location.room field (maps to NetBox location name).
COLLECTOR_ROOM_REGEX=
COLLECTOR_ROOM_REPLACE=
